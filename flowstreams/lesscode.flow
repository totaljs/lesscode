	"components": {
		"print": "<script total>\n\n\texports.id = 'print';\n\texports.name = 'Print';\n\texports.group = 'Common';\n\texports.version = '9';\n\texports.icon = 'ti ti-print';\n\texports.author = 'Peter Širka | Total.js';\n\texports.config = { repo: false, data: true, once: false, length: 0, color: '' };\n\texports.inputs = [{ id: 'input', name: 'Input' }];\n\n\texports.make = function(instance, config) {\n\n\t\tfunction serializer(key, value) {\n\t\t\treturn value && value.type === 'Buffer' && value.data ? ('<Buffer ' + value.data.splice(0, 10).map(n => n.toString(16).padLeft(2, '0')).join('') + '...') : typeof(value) === 'string' && config.length && value.length > config.length ? (value.substring(0, config.length) + '...') : value;\n\t\t}\n\n\t\tlet is = false;\n\n\t\tinstance.message = function($) {\n\n\t\t\tif (config.once && is) {\n\t\t\t\t$.destroy();\n\t\t\t\treturn;\n\t\t\t}\n\n\t\t\tlet data = $.data;\n\n\t\t\tif (config.data !== false) {\n\t\t\t\tif (data instanceof Buffer)\n\t\t\t\t\tdata = '<Buffer ' + data.toString('hex').substring(0, 10) + '...';\n\t\t\t}\n\n\t\t\tlet output = config.data && config.repo ? {} : null;\n\n\t\t\tif (config.repo) {\n\t\t\t\tif (output)\n\t\t\t\t\toutput.repo = $.repo;\n\t\t\t\telse\n\t\t\t\t\toutput = $.repository;\n\t\t\t}\n\n\t\t\tif (config.data) {\n\t\t\t\tif (output)\n\t\t\t\t\toutput.data = $.data;\n\t\t\t\telse\n\t\t\t\t\toutput = $.data;\n\t\t\t}\n\n\t\t\tif (output) {\n\t\t\t\toutput = JSON.stringify(output, serializer);\n\t\t\t\tNOW = new Date();\n\t\t\t\tinstance.status({ ts: NOW, data: output }, 200);\n\t\t\t}\n\n\t\t\tis = true;\n\t\t\t$.destroy();\n\t\t};\n\n\t\tinstance.trigger = function() {\n\t\t\tis = false;\n\t\t\tinstance.status('');\n\t\t};\n\n\t};\n\n</script>\n\n<style>\n\t.CLASS footer { border-radius: 0 0 var(--radius) var(--radius); }\n\t.CLASS footer > ui-bind { padding: 10px; }\n\t.component.CLASS_example { background-color: #ffffed; }\n\t.CLASS pre { font-size: 10px; margin: 0; padding: 5px; background-color: rgba(0,0,0,0.1); border-radius: var(--radius); tab-size: 2; }\n\t.CLASS .json { white-space: pre; }\n\t.CLASS .noscrollbar { max-height: 250px; }\n\t.CLASS .actions { font-size: 11px; cursor: pointer; }\n\t.ui-dark .component.CLASS_example { background-color: #585845; }\n\t.ui-dark .CLASS pre { background-color: rgba(100,100,100,0.1); }\n</style>\n\n<readme>\nThe component prints incoming data in a JSON format.\n</readme>\n\n<settings>\n\t<div class=\"padding\">\n\t\t<ui-component name=\"input\" path=\"?.once\" config=\"type:checkbox\"><b>Print the data once as an example</b></ui-component>\n\t\t<hr />\n\t\t<ui-component name=\"input\" path=\"?.repo\" config=\"type:checkbox\">Shows repository</ui-component>\n\t\t<ui-component name=\"input\" path=\"?.data\" config=\"type:checkbox\">Shows data</ui-component>\n\t\t<hr />\n\t\t<p><i class=\"ti ti-lightbulb-on mr5\"></i>The value below defines the maximum number of characters allowed for string values. A value of <b>0</b> will keep the original string length unchanged.</p>\n\t\t<div class=\"grid-4\">\n\t\t\t<div class=\"m\">\n\t\t\t\t<ui-component name=\"input\" path=\"?.length\" config=\"type:number;min:0\">Max. length</ui-component>\n\t\t\t</div>\n\t\t\t<div class=\"m\">\n\t\t\t\t<ui-component name=\"input\" path=\"?.color\" config=\"type:color\">Color</ui-component>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n</settings>\n\n<body>\n\t<header>\n\t\t<button class=\"exec button\" data-exec=\"=clear\">Clear</button>\n\t\t<i class=\"$ICON\"></i><ui-bind path=\"$CONFIG.once\" config=\"text:value?'Example':'Print'\"></ui-bind>\n\t</header>\n\t<footer>\n\t\t<ui-bind path=\"!$STATUS\" config=\"show\" class=\"hidden selectable block\">\n\t\t\t<div class=\"actions\">\n\t\t\t\t<span class=\"exec\" data-exec=\"=copy\" title=\"Copy\"><i class=\"ti ti-copy\"></i></span>\n\t\t\t\t<span class=\"exec\" data-exec=\"=readme\" title=\"Open in new window\"><i class=\"ti ti-window\"></i></span>\n\t\t\t</div>\n\t\t\t<ui-bind path=\"!$STATUS\" config=\"template\" class=\"block\">\n\t\t\t\t<script type=\"text/html\">\n\t\t\t\t{{ if value.ts }}\n\t\t\t\t<div class=\"fs11\"><b>Date:</b> {{ value.ts | format('[ts]') }} <i>({{ value.ts | time2 }})</i></div>\n\t\t\t\t<div class=\"noscrollbar mt5\">\n\t\t\t\t\t<pre class=\"json\">{{ value.data | debugprinter }}</pre>\n\t\t\t\t</div>\n\t\t\t\t{{ fi }}\n\t\t\t\t</script>\n\t\t\t</ui-bind>\n\t\t</ui-bind>\n\t</footer>\n</body>\n\n<script>\n\n\tThelpers.debugprinter = function(value) {\n\t\tif (value) {\n\t\t\tvalue = JSON.parse(value);\n\t\t\treturn typeof(value) === 'string' ? Thelpers.encode(value) : Thelpers.jsonformat(JSON.stringify(value, null, '\\t'));\n\t\t} else\n\t\t\treturn '';\n\t};\n\n\tTOUCH(function(exports, reinit) {\n\n\t\tif (reinit)\n\t\t\treturn;\n\n\t\tlet laststatus;\n\t\tlet lastcolor;\n\n\t\tlet autocolor = function() {\n\t\t\tif (lastcolor === exports.config.color)\n\t\t\t\treturn;\n\t\t\tlastcolor = exports.config.color;\n\t\t\texports.element.find('footer').css('background', exports.config.color ? FUNC.hex2rgba(exports.config.color, 0.3) : '');\n\t\t};\n\n\t\texports.clear = function() {\n\t\t\tif (exports.config.once)\n\t\t\t\tSETTER('approve/show', 'Are you sure you want to clear data?', ':check-circle: Clear', () => exports.trigger());\n\t\t\telse\n\t\t\t\texports.trigger();\n\t\t};\n\n\t\texports.status = function(status, isinit) {\n\t\t\tlaststatus = status;\n\t\t\tautocolor();\n\t\t};\n\n\t\texports.configure = function() {\n\t\t\texports.element.tclass('CLASS_example', exports.config.once);\n\t\t\tautocolor();\n\t\t};\n\n\t\texports.copy = function() {\n\t\t\tSETTER('clipboard/copy @copied', laststatus.data);\n\t\t};\n\n\t\texports.readme = function() {\n\t\t\tlet ts = laststatus ? laststatus.ts : null;\n\t\t\tlet status = laststatus ? JSON.parse(laststatus.data) : null;\n\t\t\tif (status != null) {\n\t\t\t\tif (typeof(status) !== 'string')\n\t\t\t\t\tstatus = JSON.stringify(status, null, '  ');\n\t\t\t} else\n\t\t\t\tstatus = '';\n\t\t\tFUNC.readme('Debug', '__Date:__ ' + (ts ? (ts.format('[ts]') + ' *(' + Thelpers.time(ts) + ')*\\n\\n') : '') + '```json\\n' + status + '\\n```');\n\t\t};\n\n\t});\n\n</script>",
		"trigger": "<script total>\n\n\texports.id = 'trigger';\n\texports.name = 'Trigger';\n\texports.group = 'Triggers';\n\texports.version = '5';\n\texports.icon = 'ti ti-start';\n\texports.author = 'Peter Širka | Total.js';\n\texports.config = { random: true, type: 'string', data: '', restart: false, prompt: false };\n\texports.outputs = [{ id: 'output', name: 'Output' }];\n\texports.kind = 'trigger';\n\n\texports.make = function(instance, config) {\n\n\t\tvar regprompt = /\\{prompt\\}/g;\n\n\t\tinstance.trigger = function(msg) {\n\n\t\t\tvar random = !config.prompt && config.random;\n\t\t\tvar val = config.data;\n\t\t\tvar prompt = msg.value || '';\n\n\t\t\tswitch (config.type) {\n\t\t\t\tcase 'number':\n\t\t\t\t\tval = random ? U.random() : val.replace(regprompt, prompt).parseFloat();\n\t\t\t\t\tbreak;\n\t\t\t\tcase 'buffer':\n\t\t\t\t\ttry {\n\t\t\t\t\t\tval = random ? Buffer.from(U.random_string()) : Buffer.from(val.replace(regprompt, prompt), 'base64');\n\t\t\t\t\t} catch (e) {\n\t\t\t\t\t\tinstance.throw(e);\n\t\t\t\t\t}\n\t\t\t\t\tbreak;\n\t\t\t\tcase 'date':\n\t\t\t\t\tval = random ? NOW.add('-' + U.random(500, 10) + ' seconds') : val.replace(regprompt, prompt).parseDate();\n\t\t\t\t\tbreak;\n\t\t\t\tcase 'object':\n\t\t\t\t\ttry {\n\t\t\t\t\t\tval = random ? {} : (new Function('return ' + val.replace(regprompt, prompt)))();\n\t\t\t\t\t} catch (e) {\n\t\t\t\t\t\tinstance.throw(e);\n\t\t\t\t\t}\n\t\t\t\t\tbreak;\n\t\t\t\tcase 'boolean':\n\t\t\t\t\tvar tmp = random ? '' : val.replace(regprompt, prompt);\n\t\t\t\t\tval = random ? U.random() % 2 === 0 : tmp === 'true' || tmp === 'on' || tmp === '1';\n\t\t\t\t\tbreak;\n\t\t\t\tdefault:\n\t\t\t\t\tval = random ? U.random_string(20) : val.replace(regprompt, prompt);\n\t\t\t\t\tbreak;\n\t\t\t}\n\n\t\t\tinstance.send('output', val);\n\t\t};\n\n\t\tconfig.restart && setTimeout(() => instance.trigger(), 5000);\n\t};\n\n</script>\n\n<style>\n\t.CLASS .padding { padding: 0 10px 10px; }\n\t.CLASS button { width: 100%; height: 24px; border: 1px solid #E0E0E0; border-radius: var(--radius); color: #000; background-color: #F0F0F0; margin: 0; }\n\t.CLASS button:hover { background-color: #F8F8F8; }\n\t.CLASS button:active { background-color: #E0E0E0; }\n\t.ui-dark .CLASS button { border-color: #404040; color: #FFF; background-color: #222; }\n\t.ui-dark .CLASS button:hover { background-color: #303030; }\n\t.ui-dark .CLASS button:active { background-color: #404040; }\n</style>\n\n<settings>\n\t<div class=\"padding\">\n\t\t<ui-component name=\"input\" path=\"?.type\" config=\"dirsource:string|String,number|Number,boolean|Boolean,date|Date,object|Object,buffer|Buffer as Base64;required:1\">Type</ui-component>\n\t\t<div class=\"mt10 m\">\n\t\t\t<ui-component name=\"input\" path=\"?.restart\" config=\"type:checkbox\">Trigger 5s after initialization.</ui-component>\n\t\t\t<ui-component name=\"input\" path=\"?.prompt\" config=\"type:checkbox\">Prompt</ui-component>\n\t\t\t<ui-bind path=\"?.prompt\" config=\"disabled\" class=\"block\">\n\t\t\t\t<ui-component name=\"input\" path=\"?.random\" config=\"type:checkbox\">Random data</ui-component>\n\t\t\t</ui-bind>\n\t\t\t<ui-bind path=\"?.prompt\" config=\"show\" class=\"block hidden m mt10\">\n\t\t\t\t<ui-component name=\"input\" path=\"?.promptlabel\" config=\"placeholder:Enter a value\"><b>Prompt label</b></ui-component>\n\t\t\t</ui-bind>\n\t\t</div>\n\t\t<ui-bind path=\"?\" config=\"hide:!value.prompt && (value.random && !value.prompt)\" class=\"hidden\">\n\t\t\t<hr />\n\t\t\t<ui-component name=\"input\" path=\"?.data\" config=\"required:1;height:250;type:multiline;maxlength:100000;monospace:1\">Data</ui-component>\n\t\t\t<ui-bind path=\"?.prompt\" config=\"show\" class=\"help hidden\">The prompt value will be assigned to the <code>{prompt}</code> keyword in the code.</ui-bind>\n\t\t</ui-bind>\n\t</div>\n</settings>\n\n<readme>\nThe component triggers data into the Flow.\n</readme>\n\n<body>\n\t<header>\n\t\t<i class=\"$ICON\"></i>$NAME\n\t</header>\n\t<div class=\"padding\">\n\t\t<button name=\"run\">Run</button>\n\t</div>\n</body>\n\n<script>\n\tTOUCH(function(exports) {\n\t\texports.click = function(el) {\n\t\t\tif (exports.config.prompt) {\n\t\t\t\tvar opt = {};\n\t\t\t\tlet key = 'trigger_' + exports.id;\n\t\t\t\topt.name = exports.config.promptlabel || 'Enter a value';\n\t\t\t\topt.value = CACHE(key) || '';\n\t\t\t\topt.centered = true;\n\t\t\t\topt.newbie = true;\n\t\t\t\topt.callback = function(val) {\n\t\t\t\t\texports.trigger({ value: val });\n\t\t\t\t\tCACHE(key, val, '1 month');\n\t\t\t\t};\n\t\t\t\tSETTER('prompt/show', opt);\n\t\t\t} else\n\t\t\t\texports.trigger();\n\t\t};\n\t});\n</script>"
	},
